# ─────────────────────────────────────────────
#  AI Habit Tracker – Backend Environment
# ─────────────────────────────────────────────

# Server
PORT=8000
NODE_ENV=development

# MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/habit_tracker?retryWrites=true&w=majority

# JWT
JWT_SECRET=change_this_to_a_very_long_random_secret_string_at_least_64_chars
JWT_EXPIRES_IN=30d

# Google Gemini — get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: gemini-2.0-flash-lite, gemini-1.5-flash, gemini-2.0-flash
GEMINI_MODEL=gemini-2.0-flash-lite

# CORS – comma-separated allowed origins
CLIENT_ORIGIN=http://localhost:5173

# Google OAuth (same Client ID as frontend VITE_GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# Email / OTP (optional in dev — OTP is logged to console)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=ccbp peuy tlkc ondr
SMTP_FROM="AI Habit Tracker <your_email@gmail.com>"
